@model IEnumerable<WebApplication2.Models.CourseEnrollment_VM>
@{
    ViewBag.Title = "Dersler";
}

<div class="container mt-4">
   

    <!-- Filtreleme Alanı -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            @using (Html.BeginForm("Courses", "Home", FormMethod.Get, new { @class = "row g-3" }))
            {
                <div class="col-md-4">
                    <label class="form-label">Döneme Göre Filtrele:</label>
                    <select name="semester" class="form-select">
                        <option value="">Tüm Dönemler</option>
                        <option value="1">1. Dönem</option>
                        <option value="2">2. Dönem</option>
                        <option value="3">3. Dönem</option>
                        <option value="4">4. Dönem</option>
                        <option value="5">5. Dönem</option>
                        <option value="6">6. Dönem</option>
                        <option value="7">7. Dönem</option>
                        <option value="8">8. Dönem</option>
                        
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Filtrele</button>
                </div>
            }
        </div>
    </div>



    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Ders Listesi</h2>
            <a href="@Url.Action("CourseAdd", "Home")" class="btn btn-primary">Ders Ekle</a>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover border">
                <thead class="table-dark">
                    <tr>
                        <th>Ders Kodu</th>
                        <th>Ders Adı</th>
                        <th>Kredi</th>
                        <th>Dönem</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Code </td>
                            <td>@item.Name</td>
                            <td>@item.Credit</td>
                            <td>@item.Semester</td>
                            <td>
                                <a href="@Url.Action("EditCourse", "Admin", new { id = item.CourseID })" class="btn btn-sm btn-info">Düzenle</a>
                                <a href="@Url.Action("DeleteCourse", "Admin", new { id = item.CourseID })" class="btn btn-sm btn-danger" onclick="return confirm('Bu dersi reddetmek istediğinize emin misiniz?')">Dersi Kaldır</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
