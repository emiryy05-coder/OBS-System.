@model IEnumerable<WebApplication2.Models.CourseEnrollment_VM>
@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewBag.Title = "DersKayıt";
}

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <strong>Hata!</strong> @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <strong>Başarılı!</strong> @TempData["Success"]
        </div>
    }


    <!-- 2. KREDİ VE DÖNEM BİLGİ KARTI (ViewBag) -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card bg-light border-info">
                <div class="card-body py-2">
                    <h6 class="card-title mb-1 text-info">Öğrenci Bilgi Paneli</h6>
                    <p class="card-text mb-0">
                        <strong>Mevcut Döneminiz:</strong> <span class="badge bg-info text-dark">@ViewBag.StudentSemester. Dönem</span> |
                        <strong>Toplam Krediniz:</strong>
                        <span class="badge @(ViewBag.CurrentCredits > 30 ? "bg-warning" : "bg-success")">
                            @ViewBag.CurrentCredits / @ViewBag.MaxCredit
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtreleme Alanı -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            @using (Html.BeginForm("DersKayıt", "Home", FormMethod.Get, new { @class = "row g-3" }))
            {
                <div class="col-md-4">
                    <label class="form-label">Döneme Göre Filtrele:</label>
                    <select name="semester" class="form-select">
                        <option value="">Tüm Dönemler</option>
                        <option value="1">1. Dönem</option>
                        <option value="2">2. Dönem</option>
                        <option value="3">3. Dönem</option>
                        <option value="4">4. Dönem</option>
                        <option value="5">5. Dönem</option>
                        <option value="6">6. Dönem</option>
                        <option value="7">7. Dönem</option>
                        <option value="8">8. Dönem</option>

                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Filtrele</button>
                </div>
            }
        </div>
    </div>



    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Ders Listesi</h2>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover border">
                <thead class="table-dark">
                    <tr>
                        <th>Ders Kodu</th>
                        <th>Ders Adı</th>
                        <th>Kredi</th>
                        <th>Dönem</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Code </td>
                            <td>@item.Name</td>
                            <td>@item.Credit</td>
                            <td>@item.Semester</td>
                            <td>
                                <a href="@Url.Action("DersiAl", "Home", new { id = item.CourseID })"
                                   class="btn btn-sm btn-primary">
                                    Ders Kayıt
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

