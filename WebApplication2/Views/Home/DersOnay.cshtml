@model IEnumerable<WebApplication2.Models.Enrollments>
@{
    ViewBag.Title = "DersOnay";
}
<div class="container mt-4">


    <!-- Filtreleme Alanı -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            @using (Html.BeginForm("DersOnay", "Home", FormMethod.Get, new { @class = "row g-3" }))
            {
                <div class="col-md-4">
                    <label class="form-label">Döneme Göre Filtrele:</label>
                    <select name="secilenDonem" class="form-select">
                        <option value="">Tüm Dönemler</option>
                        <option value="1">1. Dönem</option>
                        <option value="2">2. Dönem</option>
                        <option value="3">3. Dönem</option>
                        <option value="4">4. Dönem</option>
                        <option value="5">5. Dönem</option>
                        <option value="6">6. Dönem</option>
                        <option value="7">7. Dönem</option>
                        <option value="8">8. Dönem</option>

                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Filtrele</button>
                </div>
            }
        </div>
    </div>



    <div class="container mt-5">
        

        <div class="table-responsive">
            <table class="table table-striped table-hover border">
                <thead class="table-dark">
                    <tr>
                        <th>Ders Kodu</th>
                        <th>Ders Adı</th>
                        <th>Öğrenci Adı</th>
                        <th>Dönem</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Courses.Code </td>
                            <td>@item.Courses.Name</td>
                            <td>@item.Students.FirstName</td>
                            <td>@item.Courses.Semester</td>
                            <td>
                                @* Butona basıldığında enrollmentId parametresi ile aynı action'a gider *@
                                <a href="@Url.Action("DersOnay", "Home", new { enrollmentId = item.EnrollmentId })"
                                   class="btn btn-success btn-sm">Onayla</a>
                                @* Butona basıldığında enrollmentId parametresi ile aynı action'a gider *@
                            <a href="@Url.Action("DersRed", "Home", new { enrollmentId = item.EnrollmentId, secilenDonem = Request.QueryString["secilenDonem"] })"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Bu dersi reddetmek istediğinize emin misiniz?')">
                                Reddet
                            </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


