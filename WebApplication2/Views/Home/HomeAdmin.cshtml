@model IEnumerable<WebApplication2.Models.UserLoginVM>
@{
    ViewBag.Title = "HomeAdmin";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Öğrenci Listesi</h2>
        <a href="@Url.Action("Register", "Home")" class="btn btn-primary">Yeni Öğrenci Ekle</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Öğrenci No</th>
                    <th>Ad</th>
                    <th>Soyad</th>
                    <th>E-Mail</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.StudentNo</td>
                        <td>@item.FirstName</td>
                        <td>@item.LastName</td>
                        <td>@item.Email</td>
                        <td>
                            <a href="@Url.Action("ManageGrades", "Admin", new { id = item.StudentId })" class="btn btn-sm btn-info text-white">Not Girişi</a>
                            <a href="@Url.Action("EditStudent", "Admin", new { id = item.StudentId })" class="btn btn-sm btn-warning">Düzenle</a>
                            <a href="@Url.Action("DeleteStudent", "Admin", new { id = item.StudentId })" class="btn btn-sm btn-danger" 
                               onclick="return confirm('Bu öğrenciyi silmek istediğinize emin misiniz ?')">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

