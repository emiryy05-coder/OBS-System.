@model IEnumerable<WebApplication2.Models.GradesStudent_VM>
@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewBag.Title = "HomeUser";
}
<div class="table-responsive">
    @foreach (var donem in Model.GroupBy(x => x.Semester).OrderBy(g => g.Key))
    {

        <h4 class="mt-3">@donem.Key. Dönem</h4>
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Ders Kodu</th>
                    <th>Ders Adı</th>
                    <th>Vize</th>
                    <th>Final</th>
                    <th>Ortalama</th>

                </tr>
            </thead>
            <tbody>
                @foreach (var item in donem)
                {
                    <tr>
                        <td>@item.Code</td>
                        <td>@item.Name</td>
                        <td>@item.Midterm</td>
                        <td>@item.Final</td>
                        <td>@item.Average</td>

                    </tr>
                }
            </tbody>
        </table>
    }
</div>



