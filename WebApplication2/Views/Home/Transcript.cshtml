@model IEnumerable<WebApplication2.Models.TranscriptVM>
@{
    ViewBag.Title = "Öğrenci Transkripti";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="container mt-5">
    <!-- Sayfa Başlığı -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-mortarboard-fill me-2"></i>Akademik Transkript
        </h2>
        <button class="btn btn-outline-secondary shadow-sm" onclick="window.print()">
            <i class="bi bi-printer-fill me-1"></i> Yazdır
        </button>
    </div>

    @foreach (var semesterGroup in Model.GroupBy(x => x.Semester).OrderBy(g => g.Key))
    {
        <div class="card mb-5 border-0 shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0">@semesterGroup.Key. Dönem</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Ders Kodu</th>
                                <th>Ders Adı</th>
                                <th class="text-center">Kredi</th>
                                <th class="text-center">Ortalama</th>
                                <th class="text-center pe-4">Harf Notu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in semesterGroup)
                            {
                                <tr>
                                    <td class="ps-4">@item.Code</td>
                                    <td class="fw-bold">@item.Name</td>
                                    <td class="text-center">@item.Credit</td>
                                    <td class="text-center">@item.Average.ToString("0.00")</td>
                                    <td class="text-center pe-4">
                                        @{
                                            var letter = GetLetterGrade(item.Average);
                                            var badgeClass = (letter == "FF" || letter == "FD") ? "bg-danger" : "bg-success";
                                        }
                                        <span class="badge @badgeClass shadow-sm" style="width: 40px;">@letter</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @* --- 4.00'LÜK SİSTEM GNO HESAPLAMA --- *@
    @{
        double toplamKrediKatsayi = 0;
        int toplamKredi = 0;

        foreach (var ders in Model)
        {
            double katsayi = GetGradePoint(ders.Average);
            toplamKrediKatsayi += (katsayi * ders.Credit);
            toplamKredi += ders.Credit;
        }

        double gno4 = toplamKredi > 0 ? (toplamKrediKatsayi / toplamKredi) : 0;
    }

    <div class="row mt-4 mb-5">
        <div class="col-md-6 offset-md-6">
            <div class="card shadow border-primary">
                <div class="card-body d-flex justify-content-between align-items-center bg-light">
                    <div>
                        <h4 class="mb-0 fw-bold text-dark">GENEL ORTALAMA (AGNO)</h4>
                        <small class="text-muted">4.00'lük sistem üzerinden hesaplanmıştır.</small>
                    </div>
                    <div class="text-end">
                        <span class="display-5 fw-bold text-primary">
                            @gno4.ToString("0.00")
                        </span>
                        <div class="fw-bold text-secondary">/ 4.00</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    // Harf Notu Belirleme
    public string GetLetterGrade(double average)
    {
        if (average >= 90) return "AA";
        if (average >= 85) return "BA";
        if (average >= 80) return "BB";
        if (average >= 75) return "CB";
        if (average >= 70) return "CC";
        if (average >= 65) return "DC";
        if (average >= 60) return "DD";
        if (average >= 50) return "FD";
        return "FF";
    }

    // 4'lük Sistem Katsayı Karşılığı
    public double GetGradePoint(double average)
    {
        if (average >= 90) return 4.0; // AA
        if (average >= 85) return 3.5; // BA
        if (average >= 80) return 3.0; // BB
        if (average >= 75) return 2.5; // CB
        if (average >= 70) return 2.0; // CC
        if (average >= 65) return 1.5; // DC
        if (average >= 60) return 1.0; // DD
        if (average >= 50) return 0.5; // FD
        return 0.0; // FF
    }
}
