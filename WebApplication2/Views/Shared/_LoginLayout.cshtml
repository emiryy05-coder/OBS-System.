
@{
    ViewBag.Title = "LoginLayout";
}
<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - ASP.NET Uygulamam</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="navbar navbar-expand-md navbar-dark bg-dark shadow-sm py-2">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold fs-3" href="@Url.Action("Login", "Home")">
                <i class="bi bi-mortarboard-fill me-2"></i>OBS
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse align-items-center" id="adminNavbar">
                <ul class="navbar-nav ms-auto mb-0 fw-semibold">

                    <li class="nav-item">
                        <a class="nav-link fs-5 px-3" href="@Url.Action("LoginUser", "Home",new {@class="btn btn-hover"})">
                            Öğrenci Girişi
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fs-5 px-3" href="@Url.Action("LoginAdmin", "Home",new {@class="btn btn-hover"})">
                            Yetkili Girişi
                        </a>
                    </li>
                    <li class="fs-5 px-3">
                        @Html.ActionLink("Kayıt Ol", "Register", "Home", null, new { @class = "btn btn-primary" })
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
        <hr />

    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>





